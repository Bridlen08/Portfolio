# ============================================================
# Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── SMTP / Email Configuration ─────────────────────────────
# Gmail SMTP settings (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASSWORD=your-16-digit-app-password
# ^ Generate at: https://myaccount.google.com/apppasswords
# ^ Requires Google 2-Step Verification to be enabled

# The email address that receives contact form submissions
RECEIVER_EMAIL=perricpp@gmail.com

# ── MySQL Database ──────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=portfolio_contacts

# ── Server ─────────────────────────────────────────────────
PORT=5003

# ── Admin Panel Auth ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password
